      {
        "id": "t7exec_web",
        "type": "flograph.viz.show_web",
        "pos": [
          -1080,
          520
        ],
        "params": {
          "width": 460,
          "height": 320,
          "scale": 100
        },
        "code": "\"\"\"Executive Summary\n\nRenders the regional rollup as a styled HTML briefing \u2014 a Show Web View\nforked to prove any Python HTML output can become a canvas visual.\n\"\"\"\nNODE = {\n    \"label\": \"Executive Summary\",\n    \"category\": \"Viz\",\n    \"card\": \"webview\",\n    \"inputs\": [(\"data\", \"dataframe\")],\n    \"outputs\": [(\"view\", \"object\")],\n}\nPARAMS = [\n    {\"name\": \"width\", \"type\": \"int\", \"label\": \"Width\",\n     \"default\": 460, \"min\": 260, \"max\": 1600},\n    {\"name\": \"height\", \"type\": \"int\", \"label\": \"Height\",\n     \"default\": 320, \"min\": 200, \"max\": 2000},\n    {\"name\": \"scale\", \"type\": \"int\", \"label\": \"Scale %\",\n     \"default\": 100, \"min\": 25, \"max\": 400},\n]\n\n\ndef run(ctx, data):\n    best = data.iloc[0]\n    rows = \"\".join(\n        f\"<tr><td style='padding:4px 12px 4px 0'>{r.region}</td>\"\n        f\"<td style='text-align:right;padding:4px 12px'>{r.revenue:,.0f}</td>\"\n        f\"<td style='text-align:right;padding:4px 12px'>{r.target:,.0f}</td>\"\n        f\"<td style='text-align:right;padding:4px 0;font-weight:600;\"\n        f\"color:{'#059669' if r.attainment >= 100 else '#dc2626'}'>\"\n        f\"{r.attainment:.0f}%</td></tr>\"\n        for r in data.itertuples())\n    ctx.log(f\"summarised {len(data)} regions\")\n    return f\"\"\"\n    <div style=\"font-family: system-ui, sans-serif; padding: 20px; line-height: 1.5;\">\n      <h2 style=\"margin: 0 0 4px;\">Quarterly Briefing</h2>\n      <p style=\"margin: 0 0 14px; color: #6b7280;\">\n        <b style=\"color:#059669\">{best.region}</b> leads at\n        <b>{best.attainment:.0f}%</b> of target.</p>\n      <table style=\"border-collapse: collapse; font-size: 14px;\">\n        <tr style=\"color:#6b7280; text-align:right;\">\n          <th style=\"text-align:left; padding-right:12px;\">Region</th>\n          <th style=\"padding:0 12px;\">Revenue</th>\n          <th style=\"padding:0 12px;\">Target</th><th>Attainment</th></tr>\n        {rows}\n      </table>\n    </div>\n    \"\"\"\n",
        "label": "Executive Summary"
      },
