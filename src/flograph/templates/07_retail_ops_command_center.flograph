      {
        "id": "t7script_abc",
        "type": "flograph.scripting.python_script",
        "pos": [
          620,
          340
        ],
        "params": {},
        "code": "\"\"\"ABC Classification\n\nPareto analysis: products ranked by revenue with cumulative share, classed\nA (top ~70% of revenue), B (next ~20%) or C (the tail).\n\"\"\"\nNODE = {\n    \"label\": \"ABC Classification\",\n    \"category\": \"Scripting\",\n    \"inputs\": [(\"in1\", \"dataframe\")],\n    \"outputs\": [(\"out1\", \"dataframe\")],\n}\nPARAMS = []\n\n\ndef run(ctx, in1):\n    by_prod = (in1.groupby(\"product\", as_index=False)[\"revenue\"].sum()\n               .sort_values(\"revenue\", ascending=False).reset_index(drop=True))\n    total = by_prod[\"revenue\"].sum()\n    by_prod[\"cum_share_pct\"] = (by_prod[\"revenue\"].cumsum() / total * 100).round(1)\n    by_prod[\"abc_class\"] = by_prod[\"cum_share_pct\"].apply(\n        lambda c: \"A\" if c <= 70 else (\"B\" if c <= 90 else \"C\"))\n    ctx.log(f\"classified {len(by_prod)} products \"\n            f\"(A: {(by_prod.abc_class == 'A').sum()})\")\n    return {\"out1\": by_prod}\n",
        "label": "ABC Classification"
      },
