,[-3.08,52.202],[-2.955,52.349],[-3.185,52.434],[-3.077,52.522],[-3.041,52.717],[-3.147,52.89],[-2.985,52.956],[-2.777,52.911],[-2.699,52.995],[-2.514,52.96],[-2.381,52.998],[-1.987,53.214],[-1.813,53.113]]]}},{\"type\":\"Feature\",\"properties\":{\"code\":\"UKH\",\"region\":\"East of England\"},\"geometry\":{\"type\":\"Polygon\",\"coordinates\":[[[0.918,51.716],[0.905,51.657],[0.591,51.631],[0.811,51.601],[0.821,51.541],[0.514,51.531],[0.383,51.475],[0.211,51.49],[0.313,51.566],[0.2,51.625],[-0.012,51.646],[-0.012,51.681],[-0.501,51.6],[-0.661,51.785],[-0.554,51.827],[-0.678,51.912],[-0.592,52.111],[-0.668,52.195],[-0.465,52.323],[-0.38,52.473],[-0.415,52.579],[-0.495,52.64],[-0.031,52.662],[0.172,52.738],[0.262,52.813],[0.4,52.83],[0.584,52.967],[1.062,52.957],[1.39,52.893],[1.675,52.743],[1.741,52.532],[1.551,52.09],[1.336,51.965],[1.105,51.943],[1.229,51.926],[1.251,51.873],[1.109,51.785],[0.845,51.781],[0.918,51.716]]]}},{\"type\":\"Feature\",\"properties\":{\"code\":\"UKI\",\"region\":\"London\"},\"geometry\":{\"type\":\"Polygon\",\"coordinates\":[[[-0.012,51.646],[0.2,51.625],[0.313,51.566],[0.211,51.49],[0.097,51.516],[-0.112,51.511],[-0.245,51.489],[0.124,51.507],[0.217,51.48],[0.042,51.293],[0.002,51.329],[-0.157,51.322],[-0.252,51.364],[-0.331,51.329],[-0.318,51.394],[-0.51,51.469],[-0.501,51.6],[-0.182,51.669],[-0.012,51.681],[-0.012,51.646]]]}}]}\"\"\"\n\n\ndef run(ctx):\n    import json\n    try:\n        import geopandas as gpd\n    except ImportError:\n        raise ImportError(\n            \"geopandas is not installed \u2014 add it via Tools > Manage Packages\"\n        ) from None\n\n    features = json.loads(UK_NUTS1_GEOJSON)[\"features\"]\n    # deliberately no crs= here: pyproj CRS objects are not safe to share\n    # across engine worker threads, and these coordinates are already WGS84\n    regions = gpd.GeoDataFrame.from_features(features)\n    regions[\"region\"] = regions[\"region\"].str.replace(\n        \" (England)\", \"\", regex=False)\n    ctx.log(f\"{len(regions)} regions, bounds {regions.total_bounds.round(1)}\")\n    return {\"regions\": regions[[\"code\", \"region\", \"geometry\"]]}\n",
        "label": "UK Region Boundaries"
      },
      {
        "id": "t8join",
        "type": "flograph.transform.join",
        "pos": [
          -820,
          -560
        ],
        "params": {
          "on": "region",
          "how": "left"
        },
        "code": null,
        "label": "+ Populations"
      },
      {
        "id": "t8sort_cities",
        "type": "flograph.transform.sort",
        "pos": [
          -1040,
          -380
        ],
        "params": {
          "by": "population",
          "descending": true
        },
        "code": null,
        "label": null
      },
      {
        "id": "t8kpi_pop",
        "type": "flograph.viz.card",
        "pos": [
          -1040,
          -240
        ],
        "params": {
          "column": "population",
          "aggregation": "Sum",
          "label": "UK Population",
          "format": ",.0f",
          "width": 240,
          "height": 120
        },
        "code": null,
        "label": null
      },
      {
        "id": "t8choropleth",
        "type": "flograph.scripting.python_script",
        "pos": [
          -500,
          -560
        ],
        "params": {
          "width": 520,
          "height": 620,
          "scale": 100
        },
        "code": "\"\"\"UK Population Choropleth\n\nDraws the joined regions GeoDataFrame as a population heatmap (choropleth)\nwith the major cities marked and called out to the map margins.\n\"\"\"\nNODE = {\n    \"label\": \"UK Population Choropleth\",\n    \"category\": \"Viz\",\n    \"card\": \"figure\",\n    \"inputs\": [(\"regions\", \"dataframe\"), (\"cities\", \"dataframe\")],\n    \"outputs\": [(\"figure\", \"figure\")],\n}\nPARAMS = [\n    {\"name\": \"width\", \"type\": \"int\", \"label\": \"Width\",\n     \"default\": 520, \"min\": 260, \"max\": 1600},\n    {\"name\": \"height\", \"type\": \"int\", \"label\": \"Height\",\n     \"default\": 620, \"min\": 200, \"max\": 2000},\n    {\"name\": \"scale\", \"type\": \"int\", \"label\": \"Scale %\",\n     \"default\": 100, \"min\": 25, \"max\": 400},\n]\n\n\ndef run(ctx, regions, cities):\n    import numpy as np\n    from shapely.affinity import affine_transform\n    from matplotlib.figure import Figure  # OO API only \u2014 never pyplot in nodes\n    import matplotlib.cm as cm\n    import matplotlib.colors as mcolors\n\n    # the geodataframe carries no crs (see the boundaries node), so correct\n    # the longitude/latitude distortion by hand: at this latitude a degree\n    # of longitude covers far fewer real miles than a degree of latitude\n    mean_lat = (regions.total_bounds[1] + regions.total_bounds[3]) / 2\n    k = float(np.cos(np.radians(mean_lat)))\n    scaled = regions.geometry.apply(\n        lambda geom: affine_transform(geom, [k, 0, 0, 1, 0, 0]))\n    plot_regions = regions.assign(geometry=scaled,\n                                  pop_m=regions[\"population\"] / 1e6)\n    plot_cities = cities.assign(x=cities[\"lon\"] * k, y=cities[\"lat\"])\n\n    fig = Figure(figsize=(7.2, 7.2))\n    fig.subplots_adjust(left=0.02, right=0.98, top=0.94, bottom=0.02)\n    ax = fig.add_subplot()\n    plot_regions.plot(ax=ax, column=\"pop_m\", cmap=\"YlOrRd\", legend=False,\n                      edgecolor=\"#555555\", linewidth=0.5)\n\n    xmin, ymin, xmax, ymax = plot_regions.total_bounds\n    pad_x = (xmax - xmin) * 0.08\n    row_gap = (ymax - ymin) * 0.06\n\n    # margin callouts: west-coast cities label into the Atlantic, the rest\n    # into the North Sea, nudged apart vertically so labels never collide.\n    # Split on the *cities'* own median, not the region bbox's midpoint \u2014\n    # Northern Ireland and Shetland skew that bbox well west of where the\n    # labeled cities actually cluster, lopsiding the two columns.\n    city_xmid = plot_cities[\"x\"].median()\n    west = plot_cities[plot_cities[\"x\"] < city_xmid].sort_values(\"y\")\n    east = plot_cities[plot_cities[\"x\"] >= city_xmid].sort_values(\"y\")\n    for side, x_text, ha in ((west, xmin - pad_x, \"right\"),\n                             (east, xmax + pad_x, \"left\")):\n        last_y = ymin - (ymax - ymin)\n        for row in side.itertuples():\n            y = max(row.y, last_y + row_gap)\n            last_y = y\n            ax.annotate(\n                f\"{row.city}  ({row.population / 1e6:.1f}M)\",\n                xy=(row.x, row.y), xytext=(x_text, y),\n                ha=ha, va=\"center\", fontsize=8.5,\n                arrowprops={\"arrowstyle\": \"-\", \"color\": \"#999999\",\n                            \"linewidth\": 0.7, \"shrinkB\": 4})\n    ax.scatter(plot_cities[\"x\"], plot_cities[\"y\"],\n               s=plot_cities[\"population\"] / 1e6 * 55 + 14, color=\"#1d4ed8\",\n               edgecolor=\"white\", linewidth=0.6, zorder=5, alpha=0.85)\n\n    # manual colorbar (never pyplot in nodes) placed as a slim horizontal\n    # strip under the map \u2014 a vertical one on the side would collide with\n    # the city-label columns that flank the map on both sides\n    norm = mcolors.Normalize(vmin=plot_regions[\"pop_m\"].min(),\n                             vmax=plot_regions[\"pop_m\"].max())\n    cbar = fig.colorbar(cm.ScalarMappable(cmap=\"YlOrRd\", norm=norm), ax=ax,\n                        orientation=\"horizontal\", fraction=0.035, pad=0.03,\n                        shrink=0.35)\n    cbar.set_label(\"Population (M)\", fontsize=8.5)\n    cbar.ax.tick_params(labelsize=7.5)\n\n    # no aspect lock: the longitude pre-scaling above already corrects the\n    # UK's shape, and leaving aspect at its 'auto' default (same as every\n    # other chart node) guarantees the box is always filled edge-to-edge \u2014\n    # a fixed ratio here previously left a large dead margin on some card\n    # sizes, since matplotlib shrinks (rather than stretches) the box to\n    # honor a fixed ratio, and by how much depends on the card's own shape\n    ax.set_xlim(xmin - pad_x * 6, xmax + pad_x * 6)  # room for both columns\n    ax.set_ylim(ymin - row_gap, ymax + row_gap * 3)\n    ax.set_title(\"UK Population by Region\", fontsize=13, pad=6)\n    ax.set_axis_off()\n    ctx.log(f\"mapped {len(regions)} regions and {len(cities)} cities\")\n    return {\"figure\": fig}\n",
        "label": "UK Population Choropleth"
      },
      {
        "id": "t8folium",
        "type": "flograph.scripting.python_script",
        "pos": [
          100,
          -560
        ],
        "params": {
          "width": 460,
          "height": 380,
          "scale": 100
        },
        "code": "\"\"\"Interactive UK Map\n\nA Show Web View forked to render a live folium (Leaflet.js) map: region\nchoropleth, a city population heat layer, and hoverable city markers.\nMap tiles stream from the network when the card is viewed.\n\"\"\"\nNODE = {\n    \"label\": \"Interactive UK Map\",\n    \"category\": \"Viz\",\n    \"card\": \"webview\",\n    \"inputs\": [(\"regions\", \"dataframe\"), (\"cities\", \"dataframe\")],\n    \"outputs\": [(\"view\", \"object\")],\n}\nPARAMS = [\n    {\"name\": \"width\", \"type\": \"int\", \"label\": \"Width\",\n     \"default\": 460, \"min\": 260, \"max\": 1600},\n    {\"name\": \"height\", \"type\": \"int\", \"label\": \"Height\",\n     \"default\": 380, \"min\": 200, \"max\": 2000},\n    {\"name\": \"scale\", \"type\": \"int\", \"label\": \"Scale %\",\n     \"default\": 100, \"min\": 25, \"max\": 400},\n]\n\n\ndef run(ctx, regions, cities):\n    import json\n    try:\n        import folium\n        from folium.plugins import HeatMap\n    except ImportError:\n        raise ImportError(\n            \"folium is not installed \u2014 add it via Tools > Manage Packages\"\n        ) from None\n\n    m = folium.Map(location=[54.8, -3.5], zoom_start=5,\n                   tiles=\"cartodbpositron\")\n    folium.Choropleth(\n        geo_data=json.loads(regions.to_json()),\n        data=regions[[\"region\", \"population\"]],\n        columns=[\"region\", \"population\"],\n        key_on=\"feature.properties.region\",\n        fill_color=\"YlOrRd\", fill_opacity=0.55, line_opacity=0.4,\n        legend_name=\"Population\",\n    ).add_to(m)\n\n    peak = float(cities[\"population\"].max())\n    HeatMap([[r.lat, r.lon, r.population / peak] for r in cities.itertuples()],\n            radius=28, blur=22).add_to(m)\n    for r in cities.itertuples():\n        folium.CircleMarker(\n            location=[r.lat, r.lon], radius=4, color=\"#1d4ed8\",\n            fill=True, fill_opacity=0.9,\n            tooltip=f\"{r.city}: {r.population:,}\",\n        ).add_to(m)\n    ctx.log(f\"built folium map with {len(cities)} city markers\")\n    # m._repr_html_() wraps the map in Jupyter's \"trusted notebook\" iframe\n    # placeholder, which only ever hides behind the iframe inside a real\n    # notebook \u2014 in a plain webview the placeholder text stays visible on\n    # top of the map. get_root().render() is the standalone document, no\n    # notebook assumptions, and to_html() in the webview card accepts a\n    # plain HTML string directly.\n    return {\"view\": m.get_root().render()}\n",
        "label": "Interactive UK Map"
      },
