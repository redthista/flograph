          "data": "{\"columns\": [\"Product\", \"Region\", \"Units\", \"Revenue\"], \"rows\": [[\"Aurora Lamp\", \"North\", \"120\", \"4380\"], [\"Basalt Mug\", \"South\", \"310\", \"2790\"], [\"Cirrus Chair\", \"East\", \"85\", \"9265\"], [\"Delta Desk\", \"West\", \"42\", \"12600\"], [\"Ember Kettle\", \"North\", \"198\", \"5940\"]]}",
